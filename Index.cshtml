@{
    ViewData["Title"] = "Home Page";
    var userName = ViewData["UserName"] as string;
    var photoPath = ViewData["UserPhoto"] as string;
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        --accent-color: #0ea5e9;
    }

    body {
        background-color: #f8fafc;
        font-family: 'Inter', sans-serif;
    }

    /* Hero Section */
    .hero-wrapper {
        background: var(--primary-gradient);
        min-height: 65vh;
        border-radius: 0 0 50px 50px;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 30px;
        padding: 3rem;
        color: white;
    }

    /* Adjusted Profile Section */
    .user-welcome-box {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .profile-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid var(--accent-color);
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.1);
        flex-shrink: 0;
    }

        .profile-circle img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Card Styling */
    .nexus-card {
        border: none;
        border-radius: 20px;
        transition: all 0.3s ease;
        background: white;
    }

        .nexus-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

    .price-badge {
        background: #e0f2fe;
        color: #0369a1;
        font-weight: 700;
        padding: 5px 15px;
        border-radius: 10px;
    }

    .btn-nexus {
        background: var(--accent-color);
        color: white;
        border-radius: 12px;
        padding: 12px 25px;
        font-weight: 600;
        border: none;
    }
</style>

<div class="hero-wrapper mb-5 shadow-lg">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8 mx-auto">
                <div class="glass-card shadow-2xl">

                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="user-welcome-box">
                            <div class="profile-circle shadow">
                                @if (!string.IsNullOrEmpty(photoPath))
                                {
                                    <img src="~/StoreImg/@photoPath" alt="Profile" />
                                }
                                else
                                {
                                    <i class="fa-solid fa-user text-white" style="font-size: 2rem;"></i>
                                }
                            </div>
                            <div>
                                <h4 class="mb-0 text-white-50" style="font-size: 1.1rem;">Welcome back,</h4>
                                <h2 class="fw-bold mb-0">@(userName ?? "Member")</h2>
                            </div>
                        </div>
                    }

                    <h1 class="display-3 fw-bold mb-3">
                        Elevate Your <span style="color: var(--accent-color);">Digital</span> Life
                    </h1>
                    <p class="lead opacity-75 mb-4">
                        Discover the next generation of premium experiences curated specifically for your lifestyle.
                    </p>

                    <div class="d-flex gap-3">
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-nexus btn-lg px-5">Get Started</a>
                            <a href="#" class="btn btn-outline-light btn-lg rounded-pill px-4">Learn More</a>
                        }
                        else
                        {
                            <a href="#explore" class="btn btn-nexus btn-lg px-5">Explore My Nexus</a>
                            <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-light btn-lg rounded-pill px-4">My Account</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5" id="explore">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Featured Collections</h2>
            <p class="text-muted">Handpicked solutions for the modern era.</p>
        </div>
        <a href="#" class="text-decoration-none fw-bold" style="color: var(--accent-color);">View All <i class="fa-solid fa-arrow-right ms-1"></i></a>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card nexus-card shadow-sm h-100 p-3">
                <div style="height: 200px; background: #f1f5f9; border-radius: 15px;" class="d-flex align-items-center justify-content-center mb-3">
                    <i class="fa-solid fa-microchip fs-1 text-muted"></i>
                </div>
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="price-badge">₹ 4,999</span>
                        <small class="text-muted"><i class="fa-solid fa-star text-warning"></i> 4.9</small>
                    </div>
                    <h5 class="fw-bold">Smart Architecture</h5>
                    <p class="text-muted small">Systems design for the decentralized world.</p>
                    <button class="btn btn-nexus w-100 mt-2">View Details</button>
                </div>
            </div>
        </div>
        

        <div class="col-md-4">
            <div class="card nexus-card shadow-sm h-100 p-3">
                <div style="height: 200px; background: #f1f5f9; border-radius: 15px;" class="d-flex align-items-center justify-content-center mb-3">
                    <i class="fa-solid fa-palette fs-1 text-muted"></i>
                </div>
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="price-badge">₹ 2,500</span>
                        <small class="text-muted"><i class="fa-solid fa-star text-warning"></i> 4.8</small>
                    </div>
                    <h5 class="fw-bold">Minimalist Design</h5>
                    <p class="text-muted small">The art of subtracting until nothing remains.</p>
                    <button class="btn btn-nexus w-100 mt-2">View Details</button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card nexus-card shadow-sm h-100 p-3">
                <div style="height: 200px; background: #f1f5f9; border-radius: 15px;" class="d-flex align-items-center justify-content-center mb-3">
                    <i class="fa-solid fa-bolt fs-1 text-muted"></i>
                </div>
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="price-badge">₹ 3,200</span>
                        <small class="text-muted"><i class="fa-solid fa-star text-warning"></i> 5.0</small>
                    </div>
                    <h5 class="fw-bold">Performance Ops</h5>
                    <p class="text-muted small">Optimizing high-traffic infrastructure.</p>
                    <button class="btn btn-nexus w-100 mt-2">View Details</button>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="container py-5">
    <div class="row g-4 text-center">
        <div class="col-md-3">
            <h2 class="fw-bold text-dark mb-0">15k+</h2>
            <p class="text-muted">Active Users</p>
        </div>
        <div class="col-md-3">
            <h2 class="fw-bold text-dark mb-0">4.9/5</h2>
            <p class="text-muted">Avg. Rating</p>
        </div>
        <div class="col-md-3">
            <h2 class="fw-bold text-dark mb-0">120+</h2>
            <p class="text-muted">Premium Tools</p>
        </div>
        <div class="col-md-3">
            <h2 class="fw-bold text-dark mb-0">24/7</h2>
            <p class="text-muted">Expert Support</p>
        </div>
    </div>
</div>

<div class="py-5" style="background-color: #f1f5f9; border-radius: 50px;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-5">
                <h6 class="text-primary fw-bold text-uppercase ls-wide">The Nexus Edge</h6>
                <h2 class="display-5 fw-bold mb-4">Why choose our ecosystem?</h2>
                <p class="text-muted mb-4">We provide more than just products. We provide a seamless integration of technology and lifestyle designed to keep you ahead of the curve.</p>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="p-3 bg-white rounded-circle shadow-sm">
                            <i class="fa-solid fa-shield-halved text-primary"></i>
                        </div>
                    </div>
                    <div class="ms-3">
                        <h5 class="fw-bold">Enterprise Security</h5>
                        <p class="text-muted small">Your data is encrypted with military-grade protocols, ensuring complete privacy.</p>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="p-3 bg-white rounded-circle shadow-sm">
                            <i class="fa-solid fa-cloud-arrow-up text-primary"></i>
                        </div>
                    </div>
                    <div class="ms-3">
                        <h5 class="fw-bold">Cloud Sync</h5>
                        <p class="text-muted small">Access your collections and settings from any device, anywhere in the world.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 offset-lg-1">
                <div class="position-relative">
                    <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=800" class="img-fluid rounded-4 shadow-lg" alt="Interface Dashboard">
                    <div class="position-absolute bottom-0 start-0 m-4 p-4 bg-white rounded-4 shadow-lg d-none d-md-block" style="max-width: 250px;">
                        <p class="mb-0 fw-bold text-dark">"The best workflow tool I've used in 2026."</p>
                        <small class="text-muted">- Alex Rivera, CTO</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5 my-5">
    <div class="p-5 text-center bg-dark text-white rounded-5 shadow-2xl" style="background: var(--primary-gradient);">
        <h2 class="display-4 fw-bold mb-3">Ready to transform your workflow?</h2>
        <p class="lead mb-4 opacity-75">Join thousands of professionals who have already upgraded to Nexus.</p>
        <div class="d-flex justify-content-center gap-3">
            @if (!User.Identity.IsAuthenticated)
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-nexus btn-lg px-5">Join Now</a>
            }
            else
            {
                <a href="#explore" class="btn btn-nexus btn-lg px-5">Go to Dashboard</a>
            }
        </div>
    </div>
</div>