@model IEnumerable<PracticeMVC_DB_Identitty.Models.Courses>

@{
    ViewData["Title"] = "Our Courses";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h6 class="text-primary fw-bold text-uppercase">Catalog</h6>
        <h1 class="display-4 fw-bold">Master New Skills</h1>
        <p class="text-muted">Explore our professional-grade courses designed for your growth.</p>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card nexus-card shadow-sm h-100 p-3">
                    <div style="height: 180px; background: #f8fafc; border-radius: 15px;" class="d-flex align-items-center justify-content-center mb-3 border">
                        <i class="fa-solid fa-code-branch fs-1 text-primary opacity-50"></i>
                    </div>

                    <div class="card-body p-2 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="price-badge">₹ @item.Cour_price</span>
                            <small class="text-muted"><i class="fa-solid fa-clock me-1"></i> Self-paced</small>
                        </div>

                        <h5 class="fw-bold text-dark">@item.Cour_Name</h5>
                        <p class="text-muted small flex-grow-1">@item.Cour_Desc</p>

                        <div class="mt-3">
                            <p class="small fw-bold mb-2">Modules:</p>
                            <div class="d-flex flex-wrap gap-1 mb-3">
                                @foreach (var module in item.Cour_Cont.Split(',').Take(3))
                                {
                                    <span class="badge bg-light text-dark border rounded-pill fw-normal">@module.Trim()</span>
                                }
                            </div>
                            <a asp-action="Details" asp-route-id="@item.Cour_Id" class="btn btn-nexus w-100">View Curriculum</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
