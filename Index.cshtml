@model IEnumerable<PracticeMVC_DB_Identitty.Models.Courses>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Cour_Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cour_Desc)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cour_Cont)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cour_price)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Cour_Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Cour_Desc)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Cour_Cont)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Cour_price)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Cour_Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Cour_Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Cour_Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
