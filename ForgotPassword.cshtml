@model PracticeMVC_DB_Identitty.ViewModels.ForgotPassword



@{
    ViewData["Title"] = "Forgot Password";
}

<div class="text-danger-emphasis">@TempData["Message"]</div>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fa-solid fa-key text-primary fs-1"></i>
                        </div>
                        <h2 class="mt-3 fw-bold text-dark">Forgot Password?</h2>
                        <p class="text-muted">Enter your email and we'll send you a link to reset your password.</p>
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="fa-solid fa-envelope text-muted"></i>
                                </span>
                                <input asp-for="Email" class="form-control bg-light border-start-0 ps-0" placeholder="name@example.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm mb-3">
                            Send Reset Link
                        </button>

                        <div class="text-center">
                            <a asp-controller="Account" asp-action="Login" class="text-decoration-none small fw-bold">
                                <i class="fa-solid fa-arrow-left me-1"></i> Back to Login
                            </a>
                        </div>
                    </form>
                </div>
            </div>
            
            <p class="text-center mt-4 text-muted small">
                Having trouble? <a href="#" class="text-primary">Contact Support</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

