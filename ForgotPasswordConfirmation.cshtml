@{
    ViewData["Title"] = "Check Your Email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow border-0 rounded-4 p-5">
                <div class="card-body">
                    <div class="mb-4">
                        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                            <i class="fa-solid fa-paper-plane text-success" style="font-size: 3rem;"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold text-dark">Check your inbox</h2>
                    <p class="text-muted mt-3 fs-5">
                        If an account exists for that email, we have sent instructions on how to reset your password.
                    </p>

                    <div class="alert alert-info border-0 rounded-3 mt-4 text-start">
                        <small>
                            <i class="fa-solid fa-circle-info me-2"></i>
                            <strong>Didn't receive an email?</strong>
                            Check your spam folder or wait a few minutes. The link will expire in 2 hours for your security.
                        </small>
                    </div>

                    <div class="mt-5">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary rounded-pill px-5 fw-bold">
                            Return to Login
                        </a>
                    </div>
                </div>
            </div>

            <p class="mt-4 text-muted small">
                Still having trouble? <a href="#" class="text-decoration-none">Contact our support team</a>
            </p>
        </div>
    </div>
</div>