@{
    ViewData["Title"] = "Password Reset Successful";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-lg border-0 rounded-4 p-5">
                <div class="card-body">
                    <div class="mb-4">
                        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 100px; height: 100px;">
                            <i class="fa-solid fa-circle-check text-success" style="font-size: 4rem;"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold text-dark">Password Reset!</h2>
                    <p class="text-muted mt-3 fs-5">
                        Your password has been successfully updated. You can now use your new password to sign in to your account.
                    </p>

                    <hr class="my-4 text-muted opacity-25">

                    <div class="d-grid gap-2">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                            Sign In Now
                        </a>
                    </div>

                    <p class="mt-4 mb-0 text-muted small">
                        Securely updated on @DateTime.Now.ToString("MMMM dd, yyyy")
                    </p>
                </div>
            </div>

            <p class="mt-4 text-muted small">
                Didn't expect this? <a href="#" class="text-decoration-none">Secure your account</a>
            </p>
        </div>
    </div>
</div>